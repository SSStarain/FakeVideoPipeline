# 复制为 `.env` 并填入真实密钥：cp .env.example .env

# 必填：与 OpenAI SDK 兼容的 API Key（OpenAI、OpenRouter、其它代理均可）
OPENAI_API_KEY=

# 可选：API 基底地址。默认指向 OpenRouter；若使用官方 OpenAI 可改为：
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# 可选：模型 ID（取决于你的供应商）
OPENAI_MODEL=google/gemini-2.5-pro

# 可选：解决 YouTube 年龄限制或机器人校验——导出 Netscape 格式的 cookies.txt 后填绝对路径
# YT_DLP_COOKIES_FILE=/absolute/path/to/cookies.txt

